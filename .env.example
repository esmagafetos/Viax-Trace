# ViaX:Trace — Environment Configuration
# Copy this file to .env and fill in the values before running the server.
#
# ── Banco de dados (obrigatório) ─────────────────────────────────────────────
DATABASE_URL=postgresql://usuario:senha@localhost:5432/viax_scout

# ── Sessão (obrigatório) ──────────────────────────────────────────────────────
# Use uma string longa e aleatória: openssl rand -base64 48
SESSION_SECRET=troque_por_uma_string_longa_e_aleatoria

# ── Geocodificação premium — Google Maps (opcional) ───────────────────────────
# Habilita o modo "googlemaps" nas configurações de instância
GOOGLE_MAPS_API_KEY=

# ── GeocodeR BR — microserviço R/CNEFE (opcional) ────────────────────────────
# Habilita o modo "geocodebr" (precisão máxima para endereços brasileiros)
# Suba o serviço com: bash ~/viax-system/start-geocodebr.sh
GEOCODEBR_URL=

# ── Parser via IA (opcional) ──────────────────────────────────────────────────
# Pelo menos uma chave habilita o parser de IA na interface
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# ── App Android (artifacts/viax-mobile) ───────────────────────────────────────
# URL padrão da API que o app mobile usará caso o usuário não configure
# manualmente na tela de Setup. Exemplos:
#   - LAN local:    http://192.168.1.10:8080
#   - Termux local: http://127.0.0.1:8080
#   - Cloud:        https://api.seudominio.com.br
# Em desenvolvimento Expo, a variável precisa do prefixo EXPO_PUBLIC_ para
# ser embutida no bundle do client.
EXPO_PUBLIC_API_URL=
