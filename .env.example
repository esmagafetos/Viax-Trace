# ── Banco de dados (obrigatório) ─────────────────────────────────────────────
DATABASE_URL=postgresql://usuario:senha@localhost:5432/viax_scout

# ── Sessão (obrigatório) ──────────────────────────────────────────────────────
# Use uma string longa e aleatória: openssl rand -base64 48
SESSION_SECRET=troque_por_uma_string_longa_e_aleatoria

# ── Geocodificação premium — Google Maps (opcional) ───────────────────────────
# Habilita o modo "googlemaps" nas configurações de instância
GOOGLE_MAPS_API_KEY=

# ── GeocodeR BR — microserviço R/CNEFE (opcional) ────────────────────────────
# Habilita o modo "geocodebr" (precisão máxima para endereços brasileiros)
# Suba o serviço com: bash ~/viax-system/start-geocodebr.sh
GEOCODEBR_URL=

# ── Parser via IA (opcional) ──────────────────────────────────────────────────
# Pelo menos uma chave habilita o parser de IA na interface
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
